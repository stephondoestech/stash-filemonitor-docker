# Docker image/container names
IMAGE=stash-filemonitor:local
CONTAINER=stash-filemonitor

# Stash connection. Do not include /graphql.
STASH_URL=https://stash.lan.stephondoestech.com
STASH_API_KEY=replace-me

# Existing FileMonitor plugin path from Stash CommunityScripts.
PLUGIN_DIR=/mnt/user/appdata/stash/plugins/community/filemonitor

# Media mount. The container path should match the path Stash uses in library settings.
MEDIA_HOST_PATH=/mnt/user/deep_index
MEDIA_CONTAINER_PATH=/data/index

# Optional FileMonitor --docker mapping config path inside the container.
# Leave empty unless you mount a compose/mapping file for path translation.
FILEMONITOR_DOCKER_CONFIG=
FILEMONITOR_TRACE=false
